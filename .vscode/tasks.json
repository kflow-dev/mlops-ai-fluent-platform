{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "aifluent: cli help",
      "type": "shell",
      "command": "set -a; [ -f .env ] && source .env; set +a; python -m aifluent.cli --help",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "aifluent: api",
      "type": "shell",
      "command": "set -a; [ -f .env ] && source .env; set +a; uvicorn aifluent.api:app --reload",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Uvicorn running.*|.*Started reloader process.*",
          "endsPattern": ".*Application startup complete.*|.*Uvicorn running.*"
        }
      }
    },
    {
      "label": "aifluent: inline refactor current file",
      "type": "shell",
      "command": "set -a; [ -f .env ] && source .env; set +a; python -c \"from aifluent.vs_code.inline_refactor import suggest_inline_refactor; print(suggest_inline_refactor(r'''${file}'''))\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
