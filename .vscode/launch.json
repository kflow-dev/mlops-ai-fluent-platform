{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AIFluent API",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "aifluent.api:app",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "AIFluent CLI Help",
      "type": "python",
      "request": "launch",
      "module": "aifluent.cli",
      "args": [
        "--help"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
